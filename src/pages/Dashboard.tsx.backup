            </div>
            <div className="mt-2 font-mono text-xs text-muted-foreground tabular-nums">
              {profile.current_xp} / {xpToNext} XP
            </div>
          </div>

          <div className="card-premium p-6">
            <div className="font-mono text-[10px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Sessions</div>
            <div className="font-mono text-5xl tabular-nums">{stats.total_sessions}</div>
            <div className="mt-3 text-xs text-muted-foreground">recordings logged</div>
          </div>

          <div className="card-premium p-6">
            <div className="font-mono text-[10px] uppercase tracking-[0.25em] text-muted-foreground mb-3">Avg Score</div>
            <div className="flex items-baseline gap-2">
              <span className={cn("font-mono text-5xl tabular-nums", scoreColor(stats.average_score || 0))}>
