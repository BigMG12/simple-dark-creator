  const xpPct = Math.min(100, Math.round((profile.current_xp / xpToNext) * 100));
  const selectedSpeaker = speakers?.find(s => s.id === profile.selected_speaker_id);
  const dailyDrill = drills?.[0]; // First drill as daily drill
  const recentSessions: any[] = []; // TODO: Implement recent sessions query

  return (
    <AppShell>
      <div className="max-w-6xl mx-auto px-5 lg:px-10 py-8 lg:py-12 space-y-10">
        {/* Greeting */}
