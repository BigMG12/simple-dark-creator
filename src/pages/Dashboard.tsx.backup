          <div className="card-premium p-8 text-center">
            <div className="mx-auto h-12 w-12 rounded-full bg-gradient-primary flex items-center justify-center shadow-elegant mb-4">
              <Mic className="h-5 w-5 text-primary-foreground" />
            </div>
            <p className="font-display text-lg mb-1">Your journey starts with one word.</p>
            <p className="text-sm text-muted-foreground mb-5">Hit Record. Hear yourself. Get sharper.</p>
            <Button variant="fire" onClick={() => navigate("/record")}>
              <Mic /> Record your first session
            </Button>
